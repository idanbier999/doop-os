# =============================================================================
# Doop Dashboard — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
#   cp .env.example .env.local
#
# Required variables are marked with [REQUIRED].
# Optional variables are marked with [OPTIONAL].
# =============================================================================

# --- Supabase ---

# [REQUIRED] Your Supabase project URL.
# Find it at: Supabase Dashboard > Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# [REQUIRED] Your Supabase anonymous (public) key.
# Find it at: Supabase Dashboard > Settings > API > anon/public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# [REQUIRED] Your Supabase service role key (server-side only, never expose to browser).
# Find it at: Supabase Dashboard > Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# [REQUIRED] JWT secret used to sign Supabase-compatible tokens.
# Find it at: Supabase Dashboard > Settings > API > JWT Settings > JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret

# --- Database ---

# [REQUIRED] PostgreSQL connection string (used by Better Auth for session storage).
# Find it at: Supabase Dashboard > Settings > Database > Connection string (URI)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# --- Better Auth ---

# [REQUIRED] Secret used to sign session cookies. Generate with:
#   openssl rand -hex 32
BETTER_AUTH_SECRET=generate-a-random-32-char-string

# [REQUIRED] The base URL of your application.
# Use http://localhost:3000 for local development.
BETTER_AUTH_URL=http://localhost:3000

# --- Google OAuth ---

# [OPTIONAL] Google OAuth credentials for "Sign in with Google".
# Create at: Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client ID
# Leave blank to disable Google sign-in.
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
