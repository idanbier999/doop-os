# =============================================================================
# Doop — Environment Variables
# =============================================================================
# For local development, no env vars are needed!
# Just run: npm run dev
#
# The dev script auto-starts an embedded Postgres database.
# Set DATABASE_URL only if you want to use an external database.
# =============================================================================

# --- Database ---

# [OPTIONAL] PostgreSQL connection string.
# Leave unset for local development (embedded-postgres auto-generates one).
# Set for production or when using an external database.
# DATABASE_URL=postgresql://postgres:password@localhost:5432/doop
